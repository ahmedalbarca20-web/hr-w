# IP of the ZKTeco device on the LAN (same Wi‑Fi / router as this machine).
ZK_BRIDGE_DEVICE_IP=192.168.1.202

# Machine protocol port (default 4370).
ZK_BRIDGE_DEVICE_PORT=4370

# HTTP listen port for the bridge (HR API: DTR_ZKTECO_API_URL=http://THIS-PC-IP:8090).
ZK_BRIDGE_LISTEN_PORT=8090

# How often to poll the device (ms). Keep reasonable to avoid locking the device.
ZK_BRIDGE_POLL_MS=45000

# zkteco-js socket timeout for attendance pull (ms).
ZK_BRIDGE_SOCKET_TIMEOUT_MS=120000

# Optional: require this value in header X-Bridge-Token or X-Api-Key on GET /api/v1/bio-sync.
# ZK_BRIDGE_TOKEN=
