NODE_ENV=production
PORT=5000
APP_TIMEZONE=Asia/Baghdad
DB_TIMEZONE=+03:00

# Supabase Postgres (direct connection)
DB_DIALECT=postgres
DB_SSL=true
DB_HOST=db.qbeexwqygrtnzrbxvgxy.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=PUT_SUPABASE_DATABASE_PASSWORD_HERE

# Preferred single URI (set this in Vercel if your app reads DATABASE_URL)
# If your password contains special chars, URL-encode it (e.g. @ -> %40)
DATABASE_URL=postgresql://postgres:PUT_SUPABASE_DATABASE_PASSWORD_HERE@db.qbeexwqygrtnzrbxvgxy.supabase.co:5432/postgres

# If direct host is not IPv4 compatible in your deployment, switch to Session Pooler URI from Supabase.
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[POOLER-HOST]:6543/postgres?sslmode=require

# Serverless Postgres pool (important to avoid EMAXCONNSESSION)
DB_POOL_MAX=1
DB_POOL_MIN=0
DB_POOL_ACQUIRE_MS=30000
DB_POOL_IDLE_MS=5000

JWT_SECRET=PUT_LONG_RANDOM_SECRET_HERE
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=PUT_ANOTHER_LONG_RANDOM_SECRET_HERE
JWT_REFRESH_EXPIRES_IN=7d

SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@hr-system.local

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# Replace with your frontend URL on Vercel
CLIENT_URL=https://your-frontend-project.vercel.app

# Web Push (VAPID) — يُقرأ من خادم الـ API فقط (أضف هذه المتغيرات في مشروع الـ API على Vercel، ليس مشروع الواجهة)
# ولّد المفتاحين مرة واحدة على جهازك: npx web-push generate-vapid-keys
# ثم انسخ Public / Private هنا، وضع VAPID_SUBJECT كـ mailto:بريدك@نطاقك أو https://نطاقك — وأعد نشر الـ API
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
