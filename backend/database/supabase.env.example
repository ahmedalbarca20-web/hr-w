# ═══════════════════════════════════════════════════════════════════════════
# انسخ هذا الملف إلى backend/.env (أو دمج الأسطر مع .env الحالي)
# Supabase → Project Settings → Database → Connection string (URI)
# ═══════════════════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=5000
APP_TIMEZONE=Asia/Baghdad

# أهم سطر: يفعّل PostgreSQL بدل MySQL
DB_DIALECT=postgres

# Session pooler (موصى به للتطبيقات) أو Direct connection
# مثال (استبدل القيم من لوحة Supabase):
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require
#
# إن كانت كلمة مرور DB تحتوي على @ أو : أو # أو % أو & … رمّزها في الرابط (RFC 3986):
#   @ → %40    : → %3A    # → %23    % → %25
# مثال: كلمة المرور @MyPass123 → في URI تكتب %40MyPass123 بعد النقطتين مباشرة:
# postgresql://postgres.xxxxx:%40MyPass123@aws-....pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DATABASE_URL=

# إذا لم تستخدم DATABASE_URL، عيّن يدوياً:
# DB_HOST=db.xxxxx.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASS=your-password

# للاتصال المحلي بدون SSL: DB_SSL=false
# Supabase السحابي يحتاج SSL (الافتراضي مفعّل)
DB_SSL=true

JWT_SECRET=ضع_هنا_سلسلة_عشوائية_طويلة_32_حرفاً_على_الأقل
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=سلسلة_ثانية_مختلفة_للريفريش
JWT_REFRESH_EXPIRES_IN=7d

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@yourdomain.com

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# عنوان الواجهة الأمامية (CORS)
CLIENT_URL=https://your-frontend.vercel.app

# عنوان الـ API العام (لأجهزة البصمة على الشبكة)
PUBLIC_API_URL=https://your-api.example.com

# سوبر أدمن المنصّة — بعد تشغيل schema على Supabase نفّذ من مجلد backend:
#   node database/seed.super-admin.js
# الافتراضي في السكربت: ahmedalbarca20@gmail.com + Super@1234 إن لم تُضبط SUPER_ADMIN_PASSWORD
# ضع كلمة السر الحقيقية هنا فقط في .env المحلي (لا ترفعها لـ Git).
SUPER_ADMIN_EMAIL=ahmedalbarca20@gmail.com
SUPER_ADMIN_PASSWORD=
