# ═══════════════════════════════════════════════════════════════════════════
# انسخ الأسطر المناسبة إلى backend/.env عند استخدام PostgreSQL بدل MySQL الافتراضي.
# ═══════════════════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=5000
APP_TIMEZONE=Asia/Baghdad

DB_DIALECT=postgres

# Session pooler أو اتصال مباشر — استبدل المضيف وكلمة المرور حسب مزوّدك
# DATABASE_URL=postgresql://user:password@db.example.com:5432/hr_db?sslmode=require
#
# إن كانت كلمة مرور DB تحتوي على @ أو : أو # أو % أو & … رمّزها في الرابط (RFC 3986)
DATABASE_URL=

# إذا لم تستخدم DATABASE_URL:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=hr_db
# DB_USER=postgres
# DB_PASS=your-password

DB_SSL=true

JWT_SECRET=ضع_هنا_سلسلة_عشوائية_طويلة_32_حرفاً_على_الأقل
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=سلسلة_ثانية_مختلفة_للريفريش
JWT_REFRESH_EXPIRES_IN=7d

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@yourdomain.com

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

CLIENT_URL=https://your-frontend.vercel.app

PUBLIC_API_URL=https://your-api.example.com

SUPER_ADMIN_EMAIL=ahmedalbarca20@gmail.com
SUPER_ADMIN_PASSWORD=
