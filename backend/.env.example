# ── Server ─────────────────────────────
NODE_ENV=development
PORT=5000
# طباعة كل استعلام SQL على الطرفية (يبطّئ التطوير — اتركه معطّلاً إلا للتشخيص)
# DB_LOG_SQL=1
# Calendar day logic (check-in «today», dashboards). Iraq: Asia/Baghdad (UTC+3, no DST)
APP_TIMEZONE=Asia/Baghdad
# MySQL session time_zone offset (use +03:00 with APP_TIMEZONE Baghdad)
DB_TIMEZONE=+03:00

# ── Database (MySQL / MariaDB) ──────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hr_db
DB_USER=hr_user
DB_PASS=strongpassword

# ── JWT ────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=another_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# ── Email (SMTP) ────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@hr-system.local

# ── File Upload ─────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ── Frontend Origin (CORS) ──────────────
# Comma-separated list (no spaces required). Must include every browser origin that calls this API
# with credentials (e.g. https://hr-w-frontend.vercel.app,https://xxx-git-branch-xxx.vercel.app).
# You can mix localhost ports, LAN http://192.168.x.x:PORT, and temporary tunnels (https://*.trycloudflare.com).
# Tunnel subdomains change when the tunnel restarts — update CLIENT_URL or CORS will block the new origin.
CLIENT_URL=http://localhost:5173
# Optional: allow any https://*.vercel.app preview URL without listing each branch (dev/staging only if you accept broader origins).
# ALLOW_VERCEL_PREVIEW_ORIGINS=1

# Refresh-token cookie (httpOnly). Production default: SameSite=none + Secure so a SPA on
# another domain (e.g. Vercel) can call /api/auth/refresh with credentials.
# One-domain Docker/Nginx only: REFRESH_COOKIE_SAMESITE=strict
# REFRESH_COOKIE_SAMESITE=strict|lax|none
# REFRESH_COOKIE_SECURE=false   # only if you must run production over plain HTTP (not recommended)

# ── Platform super-admin (node database/seed.super-admin.js) ─────────────
# Default email in script: ahmedalbarca20@gmail.com — override here if needed.
# Put your real password only in local .env (never commit).
# SUPER_ADMIN_EMAIL=ahmedalbarca20@gmail.com
# SUPER_ADMIN_PASSWORD=

# ── ZK / zkteco-js (اختياري) ────────────────────────────────────────────────
# منفذ UDP محلي للربط مع الجهاز عند فشل TCP (افتراضي: عشوائي 40000–59999 لتقليل التعارض)
# ZK_UDP_LOCAL_PORT=

# ── Biometric devices (ZKTeco ADMS / push URL) ─────────────────────────────
# Base URL the *hardware* must reach (IP of this PC + API port on the LAN). Required if the browser is behind a proxy and Host header is wrong.
# Example: PUBLIC_API_URL=http://192.168.1.5:5000
PUBLIC_API_URL=

# ── ZK LAN bridge (اختياري) ───────────────────────────────────────────────
# شغّل على جهاز بنفس LAN الجهاز: npm run bridge:zk-lan — انسخ zk-lan-bridge/.env.example إلى zk-lan-bridge/.env
# ضع هنا رابط الجسر حتى الـ API (مثلاً على Vercel) يقرأ GET /api/v1/bio-sync بدل TCP مباشر لـ 192.168.x.x
# DTR_ZKTECO_API_URL=http://192.168.1.10:8090
# أو بعد ngrok: DTR_ZKTECO_API_URL=https://xxxx.ngrok-free.app

# SQLite local dev (optional — defaults to database/hr_dev.sqlite)
# DB_DIALECT=sqlite

# ── PostgreSQL (اختياري — انظر database/postgresql.env.example) ──
# DB_DIALECT=postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/hr_db?sslmode=prefer
# DB_SSL=true
# (بدون URI) DB_HOST=localhost DB_PORT=5432 DB_NAME=hr_db DB_USER=postgres DB_PASS=
