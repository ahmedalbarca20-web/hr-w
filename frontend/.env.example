# ── API ────────────────────────────────
# محلي (أو proxy في vite: يكفي /api إن كان السيرفر على 5000)
VITE_API_BASE_URL=http://localhost:5000/api
# إنتاج: عنوان الـ backend الكامل + /api (يُضبط في Vercel → Environment Variables)
# VITE_API_BASE_URL=https://api.yourdomain.com/api

# ── Local ZK agent ──
# تطوير محلي: المتصفح يتصل مباشرة بـ http://127.0.0.1:8099/execute
# إنتاج (API على نطاق عام مثل Vercel): عندما يكون VITE_API_BASE_URL على vercel.app، يُفعّل relay تلقائياً
# (shouldRelayLocalAgentToApi). على Vercel ضروري أيضاً: LOCAL_AGENT_URL + LOCAL_AGENT_TOKEN في بيئة الـ API (نفق للوكيل).
# إن وضعت توكناً على الوكيل محلياً، انسخه هنا (اختياري)
# VITE_LOCAL_AGENT_TOKEN=
# عنوان مختلف للوكيل محلياً (افتراضي http://127.0.0.1:8099)
# VITE_LOCAL_AGENT_URL=http://127.0.0.1:8099
# فرض السلوك (نادر): 1 = relay دائماً، 0 = اتصال مباشر دائماً
# VITE_LOCAL_AGENT_RELAY=

# ── App ────────────────────────────────
VITE_APP_NAME=HR System
VITE_DEFAULT_LANG=ar
