# ── API ────────────────────────────────
# محلي (أو proxy في vite: يكفي /api إن كان السيرفر على 5000)
VITE_API_BASE_URL=http://localhost:5000/api
# إنتاج: عنوان الـ backend الكامل + /api (يُضبط في Vercel → Environment Variables)
# VITE_API_BASE_URL=https://api.yourdomain.com/api

# ── App ────────────────────────────────
VITE_APP_NAME=HR System
VITE_DEFAULT_LANG=ar
