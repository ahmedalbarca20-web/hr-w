# ── API ────────────────────────────────
# محلي (أو proxy في vite: يكفي /api إن كان السيرفر على 5000)
VITE_API_BASE_URL=http://localhost:5000/api
# إنتاج: عنوان الـ backend الكامل + /api (يُضبط في Vercel → Environment Variables)
# VITE_API_BASE_URL=https://api.yourdomain.com/api

# ── Local ZK agent (browser → http://127.0.0.1:8099/execute) ──
# إن وضعت توكن على الوكيل، انسخه هنا (اختياري؛ localhost يُسمح غالباً بدون توكن)
# VITE_LOCAL_AGENT_TOKEN=
# عنوان مختلف للوكيل (افتراضي http://127.0.0.1:8099)
# VITE_LOCAL_AGENT_URL=http://127.0.0.1:8099
# واجهة على Vercel: مرّر طلبات ZK عبر الـ API (يُشترط LOCAL_AGENT_URL على الخادم مثل ngrok)
# VITE_LOCAL_AGENT_RELAY=1

# ── App ────────────────────────────────
VITE_APP_NAME=HR System
VITE_DEFAULT_LANG=ar
