LOCAL_AGENT_PORT=8099
# Keep this secret — must match LOCAL_AGENT_TOKEN (or AGENT_TOKEN) on the HR API (Vercel / backend .env).
# All ZK traffic from the cloud goes to this agent via that URL; the agent talks to the device on LAN.
LOCAL_AGENT_TOKEN=change_me_long_random_token

# Polling mode config (required for hr-local-agent.exe)
# إنتاج: https://your-app.vercel.app/api أو عنوان الـ API العام + /api (يجب أن يعمل curl من هذه الحاسبة)
CLOUD_API_BASE_URL=http://127.0.0.1:5000/api
AGENT_ID=office_1
AGENT_SHARED_TOKEN=change_me_agent_shared_token
POLL_INTERVAL_MS=2000

# Optional — periodic enqueue of pull_attendance jobs (same shape as POST /api/agent/enqueue-job).
# Interval in ms (minimum 60000). JSON array: company_id + device_id per device on the LAN PC.
# AGENT_AUTO_PULL_INTERVAL_MS=300000
# AGENT_AUTO_PULL_DEVICES_JSON=[{"company_id":1,"device_id":5},{"company_id":1,"device_id":6}]

# Optional — only if you run cloudflared manually (not needed when using Windows service install).
# CLOUDFLARED_TUNNEL_TOKEN=
